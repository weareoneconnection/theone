# Coding runtime routing. Configure the local bridge on a trusted development machine,
# or the cloud sandbox for isolated remote workspaces. Do not point Vercel at a local path.
THEONE_CODE_RUNTIME_TARGET=auto
THEONE_CODE_LOCAL_BRIDGE_URL=
THEONE_CODE_LOCAL_BRIDGE_TOKEN=
THEONE_CODE_CLOUD_SANDBOX_URL=
THEONE_CODE_CLOUD_SANDBOX_TOKEN=
THEONE_CODE_WORKSPACE_ROOTS=
THEONE_CODE_MAX_FILES=40
THEONE_CODE_MAX_FILE_BYTES=512000
THEONE_CODE_MAX_TOTAL_BYTES=4000000
THEONE_CODE_TIMEOUT_MS=60000
