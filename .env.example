# Optional: connect real providers later
DATABASE_URL="file:./dev.db"

ONEAI_BASE_URL=https://oneai-api-production.up.railway.app
ONEAI_API_KEY=replace_with_oneai_api_key
ONEAI_HEALTH_PATH=/health

ONECLAW_BASE_URL=https://oneclaw-production.up.railway.app
ONECLAW_API_KEY=replace_with_oneclaw_api_key
ONECLAW_HEALTH_PATH=/health

# Vercel Cron authentication — set to a random secret, Vercel will send it as Bearer token
CRON_SECRET=replace_with_random_secret

# Coding runtime routing. Configure the local bridge on a trusted development machine,
# or the cloud sandbox for isolated remote workspaces. Do not point Vercel at a local path.
THEONE_CODE_RUNTIME_TARGET=auto
THEONE_CODE_LOCAL_BRIDGE_URL=
THEONE_CODE_LOCAL_BRIDGE_TOKEN=
THEONE_CODE_CLOUD_SANDBOX_URL=
THEONE_CODE_CLOUD_SANDBOX_TOKEN=
THEONE_CODE_WORKSPACE_ROOTS=
THEONE_CODE_MAX_FILES=40
THEONE_CODE_MAX_FILE_BYTES=512000
THEONE_CODE_MAX_TOTAL_BYTES=4000000
THEONE_CODE_TIMEOUT_MS=60000

# Real embedding provider (OpenAI-compatible /embeddings endpoint).
# When unset, falls back to OneAI /v1/embed, then a deterministic 128-dim mock.
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
# Must match the vector column dimension (128 for mock, 1536 for text-embedding-3-small)
EMBEDDING_DIM=128

# Admin key protecting approval/policy/learning endpoints (send as Bearer token
# or x-theone-admin-key header). Unset = open (dev mode only).
THEONE_ADMIN_KEY=replace_with_random_admin_secret

# Agent Engine (self-hosted coding agent loop)
ANTHROPIC_API_KEY=
AGENT_ENGINE_MODEL=claude-sonnet-5
# Comma-separated absolute paths the agent may modify. Empty = HTTP endpoint disabled.
AGENT_ENGINE_WORKSPACES=
